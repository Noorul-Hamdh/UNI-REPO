<!DOCTYPE html>
<html>
    <head>
        <meta charset="en">
        <title>
            experiment 5
        </title>
        <style>
            #content{
                margin-top: 20px;
                font-size: 20px;
            }

            body{
                background-color: rgb(210, 249, 254);
            }

            button{
                padding: 10px 20px;
                font-size: 16px;
                margin: 10px;
                cursor: pointer;
                border-radius: 8px;
                border: none;
                background-color: #4CAF50;
                color: white;
            }

            button:hover{
                background-color: #45a049;
            }
        </style>
    </head>


    <body>
        <h1> Learn with Fun!</h1>
        <p>Click a button to learn something new!</p>

        <button onclick="showFact('animal')">Animal Fact </button>
        <button onclick="showFact('space')">Space Fact</button>
        <button onclick="showFact('math')">Math Fun</button>

        <div id="content">Let's start learning something new!</div>

        <script>
            function showFact(type){
                const contentDiv = document.getElementById("content");

                let text = "";

                if(type=='animal'){
                    text = "Elephants are the largest land animals and they have a very big trunk";
                } else if(type=='fact'){
                    text = "Earth is the only planet known to have life!";
                }else if(type=='math'){
                    const num1 = Math.floor(Math.random() * 10);
                    const num2 = Math.floor(Math.random() * 10);

                }
            }
        </script>

    </body>
</html>